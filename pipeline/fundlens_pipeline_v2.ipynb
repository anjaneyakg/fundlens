   "source": [
    "# ─── Cell T: Test Run (10 schemes) ───────────────────────────────────────────\n",
    "# Run this BEFORE Cell 1 to verify AMFI connectivity and data shape.\n",
    "# Safe — does not upload anything.\n",
    "\n",
    "import sys\n",
    "sys.path.insert(0, 'pipeline')\n",
    "\n",
    "import requests, time, json\n",
    "from datetime import date, timedelta\n",
    "from dateutil.relativedelta import relativedelta\n",
    "\n",
    "print('=== TEST RUN — 10 scheme sample ===')\n",
    "print()\n",
    "\n",
    "# Test 1: Scheme master\n",
    "print('[Test 1] Scheme master...')\n",
    "resp = requests.get('https://portal.amfiindia.com/DownloadSchemeData_Po.aspx?mf=0', timeout=30)\n",
    "lines = [l for l in resp.text.splitlines() if l.strip()]\n",
    "print(f'  ✅ {len(lines)} lines received. First 3:')\n",
    "for l in lines[:3]: print(f'    {l[:100]}')\n",
    "\n",
    "# Test 2: Current NAV\n",
    "print()\n",
    "print('[Test 2] Current NAVs...')\n",
    "resp2 = requests.get('https://www.amfiindia.com/spages/NAVAll.txt', timeout=30)\n",
    "nav_lines = [l for l in resp2.text.splitlines() if l.strip() and ';' in l]\n",
    "print(f'  ✅ {len(nav_lines)} NAV lines. Sample:')\n",
    "for l in nav_lines[:2]: print(f'    {l[:120]}')\n",
    "\n",
    "# Test 3: Historical NAV (last 30 days only)\n",
    "print()\n",
    "print('[Test 3] Historical NAV (last 30 days)...')\n",
    "today = date.today()\n",
    "from_dt = today - timedelta(days=30)\n",
    "params = {'frmdt': from_dt.strftime('%d-%b-%Y'), 'todt': today.strftime('%d-%b-%Y')}\n",
    "resp3 = requests.get(\n",
    "    'https://portal.amfiindia.com/DownloadNAVHistoryReport_Po.aspx',\n",
    "    params=params, timeout=30\n",
    ")\n",
    "h_lines = [l for l in resp3.text.splitlines() if ';' in l and l.strip()]\n",
    "print(f'  ✅ {len(h_lines)} historical NAV lines for 30 days. Sample:')\n",
    "for l in h_lines[:3]: print(f'    {l[:120]}')\n",
    "\n",
    "print()\n",
    "print('✅ All 3 AMFI endpoints responding. Safe to run Cell 1.')"
   ],
   "execution_count": null,
   "outputs": []
